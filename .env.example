# ===========================================
# AZ Inmobiliaria - Variables de entorno
# Copia este archivo a .env y rellena los valores.
# ===========================================

# --- Base de datos (PostgreSQL) ---
# Crea primero la base de datos en tu servidor PostgreSQL, luego pega aquí la URL.
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD
DATABASE_URL="postgresql://postgres:password@localhost:5432/az_inmobiliaria"

# --- BetterAuth (autenticación) ---
# URL pública de tu app. En local usar http://localhost:3000
BETTER_AUTH_BASE_URL="http://localhost:3000"
# Genera un secreto largo y aleatorio (ej: openssl rand -base64 32)
BETTER_AUTH_SECRET="cambiar_por_un_secreto_largo_y_aleatorio"

# --- Seed: usuario admin (opcional) ---
# Si no existen, el seed crea un usuario admin y la config de empresa desde config/company.json.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin123!"
ADMIN_NAME="Admin"

# --- ImageKit (subida de imágenes) ---
# Obtén las claves en https://imagekit.io/dashboard
IMAGEKIT_PUBLIC_KEY=""
IMAGEKIT_PRIVATE_KEY=""
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/tu_id"
